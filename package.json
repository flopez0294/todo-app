    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.3",
    "electron": "^41.9.2",
    "electronmon": "^2.0.4",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tree-kill": "^1.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
