  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && electron .",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "cli": "node dist/cli/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [],
